# Copy to .env and fill in with YOUR values. NEVER commit .env (it's gitignored).
# Everything real — credentials AND store identifiers — lives only in .env.
# This template ships placeholders only.

# ── Django ───────────────────────────────────────────────────────────────────
BUDTENDER_SECRET_KEY=change-me-to-a-64-char-random-string
BUDTENDER_DEBUG=0
BUDTENDER_ALLOWED_HOSTS=your-host.example.com,localhost,127.0.0.1
BUDTENDER_CSRF_ORIGINS=https://your-host.example.com
BUDTENDER_TZ=America/Los_Angeles
BUDTENDER_FIELD_KEY=                 # Fernet key material for enc:v1: secrets (optional)
REDIS_URL=                           # e.g. redis://redis:6379/0 (shared cache)
# BUDTENDER_LOCK_STORE=yakima        # optional: pin this instance to ONE store

# ── Dutchie POS — shared writer login (REAL values go in .env) ───────────────
DUTCHIE_BASE_URL=https://ash.backoffice.dutchie.com
DUTCHIE_POS_BASE_URL=https://ash.pos.dutchie.com
DUTCHIE_ORG_ID=REPLACE_ME
DUTCHIE_LSP_ID=REPLACE_ME
DUTCHIE_USERNAME=REPLACE_ME
DUTCHIE_PASSWORD=REPLACE_ME          # plaintext or enc:v1:...

# ── Stores (one block per store; names map to STORE_<UPPER>_*) ───────────────
DUTCHIE_STORES=yakima,pullman,mtvernon

STORE_YAKIMA_LOC_ID=REPLACE_ME
STORE_YAKIMA_REGISTER_ID=REPLACE_ME
STORE_YAKIMA_API_KEY=REPLACE_ME

STORE_PULLMAN_LOC_ID=REPLACE_ME
STORE_PULLMAN_REGISTER_ID=REPLACE_ME
STORE_PULLMAN_API_KEY=REPLACE_ME

STORE_MTVERNON_LOC_ID=REPLACE_ME
STORE_MTVERNON_REGISTER_ID=REPLACE_ME
STORE_MTVERNON_API_KEY=REPLACE_ME

# ── Customer-360 taste profile (optional) — read-only happytime-budtender DB ──
CUSTOMER_DB_DSN=                     # postgresql://USER:PW@db:5432/DBNAME

# ── ID-scan OCR (optional) ───────────────────────────────────────────────────
MISTRAL_API_KEY=
OPEN_AI_KEY=
