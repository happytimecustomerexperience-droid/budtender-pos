# Copy to .env and fill in. NEVER commit .env (it's gitignored).
# All credentials live here — nothing is hardcoded in the repo.

# ── Django ───────────────────────────────────────────────────────────────────
BUDTENDER_SECRET_KEY=change-me-to-a-64-char-random-string
BUDTENDER_DEBUG=0
BUDTENDER_ALLOWED_HOSTS=checkout.3dpresence.com,localhost,127.0.0.1
BUDTENDER_CSRF_ORIGINS=https://checkout.3dpresence.com
BUDTENDER_TZ=America/Los_Angeles
# Fernet key material for enc:v1: secrets (optional; plaintext passwords also work)
BUDTENDER_FIELD_KEY=
# Multi-worker cache (optional). Leave blank for single-process LocMem.
REDIS_URL=

# ── Dutchie POS — shared writer login ────────────────────────────────────────
DUTCHIE_BASE_URL=https://ash.backoffice.dutchie.com
DUTCHIE_POS_BASE_URL=https://ash.pos.dutchie.com
DUTCHIE_ORG_ID=8002
DUTCHIE_LSP_ID=1745
DUTCHIE_USERNAME=REPLACE_ME
DUTCHIE_PASSWORD=REPLACE_ME            # plaintext or enc:v1:...

# ── Stores (one block per store; names map to STORE_<UPPER>_*) ───────────────
DUTCHIE_STORES=yakima,pullman,mtvernon

STORE_YAKIMA_LOC_ID=3498
STORE_YAKIMA_REGISTER_ID=8318
STORE_YAKIMA_API_KEY=REPLACE_ME

STORE_PULLMAN_LOC_ID=3500
STORE_PULLMAN_REGISTER_ID=8240
STORE_PULLMAN_API_KEY=REPLACE_ME

STORE_MTVERNON_LOC_ID=3499
STORE_MTVERNON_REGISTER_ID=8248
STORE_MTVERNON_API_KEY=REPLACE_ME

# ── Customer-360 history (optional) — read-only Postgres of the dashboard ─────
DASHBOARD_DB_DSN=
DASHBOARD_TENANT_SCHEMA=

# ── ID-scan OCR (optional) ───────────────────────────────────────────────────
MISTRAL_API_KEY=
OPEN_AI_KEY=
